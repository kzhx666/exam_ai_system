# ==========================================
# 建筑材料与工程试卷 AI 排版系统 - 环境变量配置模板
# 使用说明：将此文件重命名为 .env，并填入真实的 API Key
# ==========================================

# 【必填】Google Gemini API Key
GEMINI_API_KEY=your_api_key_here

# 【选填】本地独立 OCR 服务地址 (默认与 docker-compose 网络一致，无需修改)
OCR_API_URL=http://paddleocr:8866/predict/system
